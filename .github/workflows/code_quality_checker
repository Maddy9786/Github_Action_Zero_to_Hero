name : code quality checker
on:
  #workflow_call:
   workflow_dispatch:
jobs: 

     runs-on: ubuntu-ubuntu-latest

     steps: 
        - name: code checkout
          uses: actions/checkout@v4

        - name:  Set up Python
          uses: actions/setup-python@v4
          with:
              python-version: '3.11'   

        - name: Install dependencies
          run: |
             python -m pip install --upgrade pip
             pip install flake8      
       
        - name: Run flake8
          uses: py-actions/flake8@v2